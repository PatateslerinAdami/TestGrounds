<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Crc32.NET" Version="1.2.0" />
    <PackageReference Include="LENet" Version="1.0.1" />
    <PackageReference Include="log4net" Version="3.3.1" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.14.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="OptimizedPriorityQueue" Version="5.1.0" />
    <PackageReference Include="RoyT.AStar" Version="3.0.2" />

    <!--
      Google.Protobuf provides the runtime types (Message, Parser, etc) used
      by the generated C# from gameserver_control.proto.

      Grpc.Tools provides the <Protobuf> MSBuild item below: it bundles
      protoc binaries for win-x64/linux-x64/osx, runs them at build time, and
      drops generated .cs into obj/Debug|Release/.../. PrivateAssets=all means
      downstream projects that consume GameServerLib don't get a transitive
      Grpc.Tools dependency — the generated types are exposed via the regular
      Google.Protobuf reference instead.
    -->
    <PackageReference Include="Google.Protobuf" Version="3.27.0" />
    <PackageReference Include="Grpc.Tools" Version="2.65.0">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!--
      Coordinator-control wire protocol. GrpcServices="None" keeps Grpc.Tools
      from generating gRPC service stubs we don't use — we only want the
      protobuf message classes. The generated code lands in
      obj/<config>/<tfm>/GameserverControl.cs and is auto-included in the
      compile.
    -->
    <Protobuf Include="Networking\Protobuf\gameserver_control.proto" GrpcServices="None" />
    <!--
      Perfetto trace format (https://perfetto.dev). Consumed by the in-process
      CPU profiler (Logging/Profiler.cs) to emit .perfetto-trace files that the
      Perfetto UI can read directly. The .proto is a verbatim copy of the
      upstream fused schema at:
      https://raw.githubusercontent.com/google/perfetto/main/protos/perfetto/trace/perfetto_trace.proto
      It is large (~19k lines) but self-contained; we only use a small slice
      of its surface (Trace / TracePacket / TrackEvent / TrackDescriptor).
    -->
    <Protobuf Include="Logging\perfetto_trace.proto" GrpcServices="None" />
  </ItemGroup>

  <ItemGroup>
    <!-- Expose internal members (e.g. Stats.GetMitigationMultiplier) to the test assembly. -->
    <InternalsVisibleTo Include="GameServerLib.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\GameMaths\GameMaths.csproj" />
    <ProjectReference Include="..\GameServerCore\GameServerCore.csproj" />
    <ProjectReference Include="..\LeaguePackets\LeaguePackets.csproj" />
    <ProjectReference Include="..\QuadTree\QuadTree.csproj" />
  </ItemGroup>

</Project>
